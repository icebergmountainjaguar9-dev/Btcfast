# Upstream mining pool (Stratum) settings
POOL_HOST=pool.example.com
POOL_PORT=3333
POOL_USER=user.worker
POOL_PASS=x

# Admin key for payout API (keep secret)
ADMIN_API_KEY=change-me-to-a-secure-token

# Local sqlite database file
DATABASE=./data.sqlite

# When true the stratum proxy will simulate shares instead of connecting to a real pool
SIMULATE_SHARES=true
